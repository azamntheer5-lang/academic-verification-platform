// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Academic citation verifier ───────────────────────────────────────────────
// A Source is a book / journal article / web page / thesis that the researcher
// is citing. Its full text content is stored page-by-page in `Page` so we can
// verify that a given quote really appears on the claimed page.

model Source {
  id          String   @id @default(cuid())
  type        String   @default("book") // book | journal | web | thesis | other
  title       String
  authors     String // newline-separated "Last, First" entries
  year        String
  publisher   String?
  city        String?
  edition     String?
  journal     String?
  volume      String?
  issue       String?
  pagesRange  String? // e.g. "12-45" for a journal article
  url         String?
  doi         String?
  language    String? @default("ar") // ar | en
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pages      Page[]
  citations  Citation[]
}

model Page {
  id        String @id @default(cuid())
  sourceId  String
  number    Int // 1-based page number as it appears in the source
  content   String
  source    Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, number])
  @@index([sourceId])
}

model Citation {
  id          String   @id @default(cuid())
  sourceId    String
  quote       String // the verbatim text the researcher wants to cite
  claim       String? // optional paraphrase / claim to verify semantically
  pageNumber  Int? // the page the researcher claims the quote is on
  style       String   @default("apa") // apa | mla | chicago | harvard
  status      String   @default("unverified") // verified | partial | mismatch | unverified | not_found
  confidence  Float    @default(0) // 0..1
  exactMatch  Boolean  @default(false)
  matchedPage Int? // the page where the quote was actually found (if any)
  matchScore  Float    @default(0) // best fuzzy similarity 0..1
  llmVerdict  String? // supported | not_supported | partial | unknown
  llmNote     String? // human-readable explanation from the model
  createdAt   DateTime @default(now())

  source      Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
}
